# .env.example
# Copiar a .env y llenar con valores reales
# NUNCA subir .env a GitHub

# ─── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── FastAPI ────────────────────────────────────────────
ENVIRONMENT=development
# En Railway cambiar a: ENVIRONMENT=production

# ─── Frontend (Vite) ────────────────────────────────────
# Estas variables van en frontend/.env
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_API_URL=/api

# ─── Google OAuth ───────────────────────────────────────
# Obtener en: console.cloud.google.com
# Configurar en: supabase.com → Authentication → Providers → Google
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# ─── Anthropic / Claude API ─────────────────────────────
# Obtener en: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxx

# ─── Notas ──────────────────────────────────────────────
# Redirect URL para Google OAuth (configurar en Google Cloud Console):
#   https://xxxxxxxxxxxx.supabase.co/auth/v1/callback
#
# En Railway, agregar todas las variables del backend directamente
# en el dashboard de Railway (no necesita archivo .env en producción)
